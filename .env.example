# Database (Supabase / PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Application URL (used for generating survey links)
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# Admin session JWT secret (min 32 random characters)
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# Survey token JWT secret (min 32 random characters, different from AUTH_SECRET)
JWT_SECRET="generate-with-openssl-rand-base64-32"

# Admin credentials — used only during `prisma db seed`
ADMIN_USERNAME="your-admin-username"
ADMIN_PASSWORD="your-strong-password"

# API key for remote rating sync (optional)
SYNC_API_KEY="generate-random-key"
